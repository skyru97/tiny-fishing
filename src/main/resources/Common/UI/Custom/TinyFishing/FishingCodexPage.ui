$C = "../Common.ui";

@TitleStyle = LabelStyle(
  FontSize: 30,
  TextColor: #eef6ff,
  FontName: "Secondary",
  RenderBold: true,
  LetterSpacing: 0.12
);

@BodyStyle = LabelStyle(
  FontSize: 14,
  TextColor: #aebfd1,
  Wrap: true
);

@CaptionStyle = LabelStyle(
  FontSize: 12,
  TextColor: #8fa4ba,
  RenderBold: true,
  LetterSpacing: 0.15
);

@SummaryStyle = LabelStyle(
  FontSize: 22,
  TextColor: #eef6ff,
  FontName: "Secondary",
  RenderBold: true
);

Group #CodexRoot {
  Anchor: (Full: 0);
  LayoutMode: MiddleCenter;

  Group {
    Anchor: (Full: 0);
    Background: #04070d(0.68);
  }

  Group {
    Anchor: (Width: 980, Height: 680);
    LayoutMode: Top;
    Padding: (Full: 22);
    Background: #0b1420(0.97);

    Group {
      Anchor: (Height: 72);
      LayoutMode: Left;

      Group {
        Anchor: (Width: 640, Height: 72, Right: 18);
        LayoutMode: Top;

        Label {
          Anchor: (Height: 36);
          Style: @TitleStyle;
          Text: "Fishing Codex";
        }

        Label {
          Anchor: (Height: 22, Top: 2);
          Style: (...@BodyStyle, FontSize: 13, TextColor: #8fa4ba);
          Text: "Known catches first. Unknown fish stay hidden.";
        }
      }

      Group {
        Anchor: (Width: 300, Height: 62, Top: 4);
        Padding: (Left: 16, Top: 10, Right: 16, Bottom: 10);
        LayoutMode: Top;
        Background: #101b29(0.96);

        Label {
          Anchor: (Height: 16);
          Style: @CaptionStyle;
          Text: "Discovered";
        }

        Label #Summary {
          Anchor: (Height: 26, Top: 2);
          Style: @SummaryStyle;
          Text: "0 / 0";
        }
      }
    }

    Group {
      Anchor: (Height: 10);
    }

    Group {
      FlexWeight: 1;
      Background: #0d1825(0.54);
      Padding: (Left: 10, Top: 10, Right: 2, Bottom: 10);
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;

      Group #FishList {
        LayoutMode: LeftCenterWrap;
      }
    }
  }
}
